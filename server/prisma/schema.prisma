generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String         @id @default(uuid())
  email                String         @unique
  passwordHash         String
  firstName            String
  lastName             String
  pernerNumber         String         @unique
  role                 UserRole       @default(USER)
  isActive             Boolean        @default(true)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  ownedRequests        ShiftRequest[] @relation("OwnedRequests")
  acceptedRequests     ShiftRequest[] @relation("AcceptedRequests")

  notifications        Notification[] @relation("NotificationsForUser")
  notificationsSent    Notification[] @relation("NotificationsFromActor")
  auditLogsAuthored    AuditLog[]

  @@map("users")
}

model Park {
  id        String     @id
  name      String     @unique
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  locations Location[]

  @@map("parks")
}

model Location {
  id        String         @id @default(uuid())
  name      String
  area      String
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  parkId    String
  park      Park           @relation(fields: [parkId], references: [id], onDelete: Restrict)

  requests  ShiftRequest[]

  @@unique([parkId, area, name])
  @@index([parkId, area])
  @@map("locations")
}

model ShiftRequest {
  id               String             @id @default(uuid())
  status           ShiftRequestStatus @default(OPEN)

  role             String
  date             String
  start            String
  end              String
  isOvernight      Boolean            @default(false)

  startsAt         DateTime
  
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  pendingAt        DateTime?
  acceptedAt       DateTime?

  locationId       String
  ownerId          String
  acceptedByUserId String?

  location         Location           @relation(fields: [locationId], references: [id], onDelete: Restrict)
  owner            User               @relation("OwnedRequests", fields: [ownerId], references: [id], onDelete: Cascade)
  acceptedByUser   User?              @relation("AcceptedRequests", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  notifications    Notification[]

  @@index([locationId, date, status])
  
  @@index([ownerId, createdAt])
  @@index([status, startsAt])
  @@index([acceptedByUserId, createdAt])
  @@map("shift_requests")
}

model Notification {
  id             String           @id @default(uuid())
  type           NotificationType
  createdAt      DateTime         @default(now())
  readAt         DateTime?

  userId         String
  actorUserId    String?
  shiftRequestId String?

  reasonCode     RejectReason?

  user           User             @relation("NotificationsForUser", fields: [userId], references: [id], onDelete: Cascade)
  actorUser      User?            @relation("NotificationsFromActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  shiftRequest   ShiftRequest?    @relation(fields: [shiftRequestId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@index([shiftRequestId])
  @@index([userId, readAt, createdAt])
  @@index([userId, type, createdAt], map: "notifications_userId_type_createdAt_idx")
  @@index([userId, type, readAt, createdAt], map: "notifications_userId_type_readAt_createdAt_idx")
  @@map("notifications")
}

model AuditLog {
  id          String          @id @default(uuid())
  action      AuditAction
  entityType  AuditEntityType
  entityId    String?
  details     Json?
  createdAt   DateTime        @default(now())

  actorUserId String?
  actorUser   User?           @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

enum UserRole {
  USER
  ADMIN
  SUPERADMIN
}

enum AuditAction {
  CREATE
  UPDATE
  ACTIVATE
  DEACTIVATE
  CANCEL
  REOPEN
  ROLE_CHANGE
}

enum AuditEntityType {
  USER
  PARK
  LOCATION
  REQUEST
}

enum ShiftRequestStatus {
  OPEN
  PENDING
  ACCEPTED
  CANCELED
  EXPIRED
}

enum NotificationType {
  NEEDS_CONFIRMATION
  REQUEST_ACCEPTED
  REQUEST_REJECTED
  DECLINED_BY_YOU
}

enum RejectReason {
  OVERTIME_LIMIT
  INCORRECT_PERNER
  OTHER
}
